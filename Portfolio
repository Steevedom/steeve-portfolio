<title>Portfolio BTS SIO SISR – MOUSSOUNGOU ATA-YIS Steeve</title>
<link href="https://fonts.googleapis.com/css2?family=Syne:wght@400;600;700;800&family=DM+Sans:ital,wght@0,300;0,400;0,500;1,300&display=swap" rel="stylesheet">
<style>
:root {
  --bg:       #020609;
  --bg2:      #05080f;
  --bg3:      #080d16;
  --panel:    #0a1220;
  --blue:     #1D4ED8;
  --blue2:    #2563EB;
  --sky:      #38BDF8;
  --silver:   #475569;
  --slate:    #64748B;
  --white:    #CBD5E1;
  --white2:   #E2E8F0;
  --accent:   #0EA5E9;
  --green:    #059669;
  --orange:   #D97706;
  --red:      #DC2626;
  --purple:   #7C3AED;
  --border:   rgba(14,165,233,0.1);
}

*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
html{scroll-behavior:smooth}
body{font-family:'DM Sans',sans-serif;background:var(--bg);color:var(--white);overflow-x:hidden}

/* NAV */
nav{position:fixed;top:0;left:0;right:0;z-index:100;display:flex;align-items:center;justify-content:space-between;padding:0 2.5rem;height:60px;background:rgba(2,6,9,0.97);backdrop-filter:blur(20px);border-bottom:1px solid var(--border)}
.nav-brand{font-family:'Syne',sans-serif;font-weight:800;font-size:0.95rem;color:var(--accent);letter-spacing:0.06em;text-transform:uppercase}
.nav-links{display:flex;gap:1.8rem;list-style:none}
.nav-links a{text-decoration:none;color:var(--slate);font-size:0.82rem;font-weight:500;transition:color .2s}
.nav-links a:hover{color:var(--white2)}
.nav-badge{background:var(--blue);color:white;font-size:0.68rem;font-weight:700;padding:4px 10px;border-radius:20px;letter-spacing:0.06em;text-transform:uppercase}

/* HERO */
.hero{min-height:100vh;display:flex;flex-direction:column;justify-content:center;padding:100px 3rem 4rem;position:relative;overflow:hidden}
.hero::after{content:'';position:absolute;top:-150px;right:-150px;width:600px;height:600px;background:radial-gradient(circle,rgba(14,165,233,0.07) 0%,transparent 70%);pointer-events:none}
.hero::before{content:'';position:absolute;bottom:-200px;left:-100px;width:500px;height:500px;background:radial-gradient(circle,rgba(29,78,216,0.05) 0%,transparent 70%);pointer-events:none}
.eyebrow{display:inline-flex;align-items:center;gap:8px;font-size:0.75rem;font-weight:700;letter-spacing:0.14em;text-transform:uppercase;color:var(--accent);margin-bottom:1.5rem}
.eyebrow::before{content:'';display:block;width:28px;height:2px;background:var(--accent)}
.hero h1{font-family:'Syne',sans-serif;font-size:clamp(3rem,5.5vw,5rem);font-weight:800;line-height:1.02;color:var(--white2);margin-bottom:0.4rem}
.hero h1 span{background:linear-gradient(135deg,var(--blue2),var(--accent));-webkit-background-clip:text;-webkit-text-fill-color:transparent}
.hero-sub{font-size:1rem;color:var(--slate);font-weight:300;margin:1.5rem 0 2.5rem;max-width:580px;line-height:1.8}
.hero-sub strong{color:var(--white);font-weight:500}
.chips{display:flex;flex-wrap:wrap;gap:1rem;margin-bottom:3rem}
.chip{display:flex;align-items:center;gap:7px;background:rgba(14,165,233,0.06);border:1px solid rgba(14,165,233,0.15);padding:7px 14px;border-radius:8px;font-size:0.82rem;color:var(--slate)}
.ctas{display:flex;gap:1rem;flex-wrap:wrap}
.btn{display:inline-flex;align-items:center;gap:8px;padding:11px 26px;border-radius:8px;font-weight:600;font-size:0.875rem;text-decoration:none;transition:all .2s}
.btn-p{background:var(--blue2);color:white}.btn-p:hover{background:var(--blue);transform:translateY(-2px)}
.btn-o{background:transparent;color:var(--slate);border:1px solid rgba(100,116,139,0.3)}.btn-o:hover{border-color:var(--sky);color:var(--white2)}
.scroll-hint{position:absolute;bottom:2.5rem;left:50%;transform:translateX(-50%);display:flex;flex-direction:column;align-items:center;gap:8px;color:var(--silver);font-size:0.7rem;letter-spacing:0.1em;text-transform:uppercase}
.scroll-line{width:1px;height:36px;background:linear-gradient(to bottom,var(--blue2),transparent);animation:pulse 1.8s ease-in-out infinite}
@keyframes pulse{0%,100%{opacity:.3}50%{opacity:1}}

/* SECTIONS */
section{padding:5rem 3rem;position:relative}
.s-dark{background:rgba(4,8,14,0.7)}
.stag{font-size:0.72rem;font-weight:700;letter-spacing:0.16em;text-transform:uppercase;color:var(--accent);display:flex;align-items:center;gap:8px;margin-bottom:0.7rem}
.stag::before{content:'';display:block;width:18px;height:2px;background:var(--accent)}
.stitle{font-family:'Syne',sans-serif;font-size:clamp(1.8rem,2.8vw,2.4rem);font-weight:700;color:var(--white2);line-height:1.2;margin-bottom:2.5rem}
hr.div{width:100%;height:1px;background:linear-gradient(to right,rgba(14,165,233,0.25),transparent);border:none;margin:0}

/* PROFIL GRID */
.g2{display:grid;grid-template-columns:1fr 1fr;gap:1.5rem}
.card{background:rgba(5,8,15,0.9);border:1px solid var(--border);border-radius:14px;padding:1.75rem}
.card h3{font-family:'Syne',sans-serif;font-size:0.95rem;font-weight:700;color:var(--accent);margin-bottom:1.2rem;display:flex;align-items:center;gap:8px}
.row{display:flex;justify-content:space-between;align-items:center;padding:9px 0;border-bottom:1px solid rgba(14,165,233,0.05);font-size:0.83rem}
.row:last-child{border-bottom:none}
.row .lbl{color:var(--silver)}
.row .val{color:var(--white);font-weight:500;text-align:right}

/* COMPÉTENCES */
.comp-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(270px,1fr));gap:1.2rem}
.comp-card{background:rgba(3,6,12,0.95);border:1px solid var(--border);border-radius:12px;padding:1.4rem;transition:border-color .2s,transform .2s}
.comp-card:hover{border-color:rgba(14,165,233,0.3);transform:translateY(-4px)}
.comp-head{display:flex;align-items:center;gap:10px;margin-bottom:1rem}
.comp-icon{width:38px;height:38px;border-radius:8px;display:flex;align-items:center;justify-content:center;font-size:1.1rem}
.comp-card h4{font-family:'Syne',sans-serif;font-size:0.9rem;font-weight:700;color:var(--white2)}
.comp-card p{font-size:0.8rem;color:var(--silver);line-height:1.65}
.tags{display:flex;flex-wrap:wrap;gap:5px;margin-top:0.9rem}
.tag{background:rgba(29,78,216,0.1);border:1px solid rgba(29,78,216,0.2);color:var(--sky);font-size:0.7rem;font-weight:600;padding:3px 9px;border-radius:20px}

/* STAGES */
.stages-grid{display:grid;grid-template-columns:1fr 1fr;gap:1.5rem}
.stage-card{background:rgba(3,6,12,0.95);border:1px solid var(--border);border-radius:14px;padding:1.75rem;position:relative;overflow:hidden;transition:border-color .2s}
.stage-card::before{content:'';position:absolute;top:0;left:0;width:3px;height:100%}
.stage-card.s1::before{background:linear-gradient(to bottom,var(--blue2),var(--accent))}
.stage-card.s2::before{background:linear-gradient(to bottom,var(--purple),var(--sky))}
.stage-card:hover{border-color:rgba(14,165,233,0.25)}
.stage-badge{display:inline-flex;align-items:center;gap:6px;font-size:0.7rem;font-weight:700;letter-spacing:0.08em;text-transform:uppercase;padding:3px 10px;border-radius:20px;margin-bottom:1rem}
.badge-sisr{background:rgba(14,165,233,0.1);border:1px solid rgba(14,165,233,0.2);color:var(--accent)}
.badge-dev{background:rgba(124,58,237,0.1);border:1px solid rgba(124,58,237,0.2);color:#A78BFA}
.stage-card h4{font-family:'Syne',sans-serif;font-size:1rem;font-weight:700;color:var(--white2);margin-bottom:0.3rem}
.stage-meta{font-size:0.78rem;color:var(--silver);margin-bottom:1rem;display:flex;flex-wrap:wrap;gap:12px}
.stage-meta span{display:flex;align-items:center;gap:5px}
.missions-list{list-style:none;margin-bottom:1rem}
.missions-list li{display:flex;align-items:flex-start;gap:8px;padding:5px 0;font-size:0.82rem;color:var(--slate);border-bottom:1px solid rgba(14,165,233,0.04)}
.missions-list li:last-child{border-bottom:none}
.missions-list li::before{content:'▸';color:var(--accent);margin-top:1px;flex-shrink:0}

/* TECHNOLOGIES */
.tech-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(120px,1fr));gap:0.9rem}
.tech-item{background:rgba(3,6,12,0.95);border:1px solid var(--border);border-radius:10px;padding:1.1rem 0.8rem;text-align:center;transition:border-color .2s,transform .2s}
.tech-item:hover{border-color:rgba(14,165,233,0.3);transform:translateY(-3px)}
.tech-item .ti{font-size:1.6rem;margin-bottom:0.4rem}
.tech-item span{display:block;font-size:0.75rem;font-weight:600;color:var(--slate)}
.tech-bar{margin-top:7px;height:3px;border-radius:2px;background:rgba(14,165,233,0.08);overflow:hidden}
.tech-fill{height:100%;border-radius:2px;background:linear-gradient(to right,var(--blue2),var(--accent))}

/* ÉPREUVES */
.epreuve-grid{display:grid;grid-template-columns:1fr 1fr;gap:1.5rem}
.epreuve-card{background:rgba(3,6,12,0.95);border:1px solid var(--border);border-radius:14px;padding:1.75rem}
.epreuve-num{font-family:'Syne',sans-serif;font-size:2.2rem;font-weight:800;color:rgba(14,165,233,0.12);line-height:1;margin-bottom:0.4rem}
.epreuve-card h4{font-family:'Syne',sans-serif;font-size:1rem;font-weight:700;color:var(--white2);margin-bottom:0.75rem}
.epreuve-card p{font-size:0.82rem;color:var(--silver);line-height:1.7}
.epreuve-list{list-style:none;margin-top:1rem}
.epreuve-list li{display:flex;align-items:flex-start;gap:8px;padding:4px 0;font-size:0.8rem;color:var(--slate)}
.epreuve-list li::before{content:'✓';color:var(--green);flex-shrink:0}

/* PROJETS */
.projets-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(280px,1fr));gap:1.2rem}
.projet-card{background:rgba(3,6,12,0.95);border:1px solid var(--border);border-radius:12px;padding:1.5rem;transition:border-color .2s,transform .2s}
.projet-card:hover{border-color:rgba(14,165,233,0.25);transform:translateY(-3px)}
.projet-card h4{font-family:'Syne',sans-serif;font-size:0.95rem;font-weight:700;color:var(--white2);margin-bottom:0.6rem}
.projet-card p{font-size:0.8rem;color:var(--silver);line-height:1.65}
.projet-link{display:inline-flex;align-items:center;gap:6px;margin-top:1rem;font-size:0.78rem;font-weight:600;color:var(--sky);text-decoration:none;transition:color .2s}
.projet-link:hover{color:var(--white2)}

/* TABLEAU SYNTHÈSE */
.synth-wrap{overflow-x:auto;border-radius:12px;border:1px solid var(--border)}
table{width:100%;border-collapse:collapse;font-size:0.82rem}
th{background:rgba(14,165,233,0.08);color:var(--sky);font-family:'Syne',sans-serif;font-size:0.72rem;font-weight:700;text-transform:uppercase;letter-spacing:0.08em;padding:12px 14px;text-align:left;border-bottom:1px solid rgba(14,165,233,0.12)}
td{padding:11px 14px;color:var(--slate);border-bottom:1px solid rgba(14,165,233,0.04);vertical-align:top;line-height:1.5}
tr:hover td{background:rgba(14,165,233,0.03)}
td:first-child{color:var(--white);font-weight:500}
.bdg{display:inline-flex;font-size:0.68rem;font-weight:700;padding:2px 8px;border-radius:4px}
.bdg-g{background:rgba(5,150,105,0.1);border:1px solid rgba(5,150,105,0.2);color:#34D399}
.bdg-b{background:rgba(14,165,233,0.1);border:1px solid rgba(14,165,233,0.2);color:var(--sky)}
.bdg-o{background:rgba(215,119,6,0.1);border:1px solid rgba(215,119,6,0.2);color:#FCD34D}

/* VEILLE */
.veille-card{background:rgba(3,6,12,0.95);border:1px solid var(--border);border-radius:14px;padding:2rem}
.veille-card h3{font-family:'Syne',sans-serif;font-size:1rem;font-weight:700;color:var(--accent);margin-bottom:1rem}
.veille-card p{font-size:0.85rem;color:var(--silver);line-height:1.75}

/* BILAN */
.bilan-grid{display:grid;grid-template-columns:1fr 1fr;gap:1.5rem}
.bilan-card{background:rgba(3,6,12,0.95);border:1px solid var(--border);border-radius:14px;padding:1.75rem}
.bilan-card h3{font-family:'Syne',sans-serif;font-size:0.95rem;font-weight:700;color:var(--white2);margin-bottom:1.1rem;display:flex;align-items:center;gap:8px}
.bilan-item{display:flex;align-items:flex-start;gap:9px;padding:7px 0;font-size:0.82rem;color:var(--silver);border-bottom:1px solid rgba(14,165,233,0.04)}
.bilan-item:last-child{border-bottom:none}
.dot{width:6px;height:6px;border-radius:50%;margin-top:5px;flex-shrink:0}

/* CONTACT */
.contact-s{text-align:center;padding:4rem 3rem;background:rgba(2,5,10,0.98);border-top:1px solid var(--border)}
.contact-chips{display:flex;gap:1rem;justify-content:center;flex-wrap:wrap;margin-top:1.5rem}

/* FOOTER */
footer{text-align:center;padding:1.8rem;background:#010406;border-top:1px solid rgba(14,165,233,0.05);font-size:0.75rem;color:var(--silver)}

/* ANIMATIONS */
@keyframes fadeUp{from{opacity:0;transform:translateY(28px)}to{opacity:1;transform:translateY(0)}}
.fu{animation:fadeUp .65s ease forwards}
.d1{animation-delay:.1s;opacity:0}.d2{animation-delay:.22s;opacity:0}.d3{animation-delay:.36s;opacity:0}.d4{animation-delay:.5s;opacity:0}

@media(max-width:768px){
  nav{padding:0 1.2rem}.nav-links{display:none}
  section{padding:3rem 1.4rem}.hero{padding:85px 1.4rem 3rem}
  .g2,.stages-grid,.epreuve-grid,.bilan-grid{grid-template-columns:1fr}
}
</style>
</head>
